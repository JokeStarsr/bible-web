# 复制本文件为 .env 并填写真实值后启动 Docker Compose
# cp .env.example .env

# 数据库
DB_USER=bible_user
DB_PASS=bible_pass

# Redis
REDIS_PASS=

# 邮件服务（联系牧者、验证码）
# QQ 邮箱 SMTP 配置：
#   1. 登录 QQ 邮箱 -> 设置 -> 账户 -> 开启 SMTP
#   2. 生成 16 位授权码（不是邮箱登录密码）
#   3. 将授权码填入 MAIL_PASS
MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USER=852341467@qq.com
MAIL_PASS=你的QQ邮箱授权码

# JWT 密钥（生产环境必须替换为强随机字符串）
JWT_SECRET=change-me-to-a-long-random-string-at-least-256-bits

# DeepSeek / LLM
LLM_PROVIDER=deepseek
LLM_API_KEY=你的DeepSeek_API_Key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=60
