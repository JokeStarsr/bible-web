# 复制本文件为 .env 并填写真实值后启动 Docker Compose
# cp .env.example .env

# 数据库
DB_USER=bible_user
DB_PASS=bible_pass

# Redis
REDIS_PASS=

# 邮件服务（联系牧者、注册验证码共用此配置）
# 你的 852341467@qq.com 只作为收件人，发件人请使用邮件推送服务
#
# 推荐：阿里云邮件推送（DirectMail）——到 QQ 邮箱到达率最好
#   1. 购买/准备一个域名（如 yourdomain.com）
#   2. 阿里云控制台 -> 邮件推送 -> 配置发信域名、发信地址
#   3. 获取 SMTP 账号/密码，填入下方
#   4. MAIL_FROM 填你在阿里云配置的发信地址，如 noreply@yourdomain.com
#
# 备选：SendGrid / Mailgun / Resend（有免费额度，但到国内邮箱可能进垃圾箱）
#   1. 注册账号并验证域名
#   2. 获取 SMTP 信息或 API Key
#   3. MAIL_FROM 填你的域名邮箱，如 noreply@yourdomain.com
#
MAIL_HOST=smtpdm.aliyun.com
MAIL_PORT=465
MAIL_USER=你的SMTP账号
MAIL_PASS=你的SMTP密码
MAIL_FROM=noreply@yourdomain.com

# 联系牧者表单收件邮箱（保持你的 QQ 邮箱即可）
MAIL_PASTOR_TO=852341467@qq.com

# JWT 密钥（生产环境必须替换为强随机字符串）
JWT_SECRET=change-me-to-a-long-random-string-at-least-256-bits

# DeepSeek / LLM
LLM_PROVIDER=deepseek
LLM_API_KEY=你的DeepSeek_API_Key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=60
