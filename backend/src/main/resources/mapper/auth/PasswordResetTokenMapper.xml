<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bible.module.auth.mapper.PasswordResetTokenMapper">

    <resultMap id="PasswordResetTokenResultMap" type="com.bible.module.auth.entity.PasswordResetToken">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="token" property="token"/>
        <result column="expires_at" property="expiresAt"/>
        <result column="used_at" property="usedAt"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <insert id="insert">
        INSERT INTO password_reset_tokens(id, user_id, token, expires_at, used_at, created_at)
        VALUES(gen_random_uuid(), #{userId}, #{token}, #{expiresAt}, #{usedAt}, NOW())
    </insert>

    <select id="findByToken" resultMap="PasswordResetTokenResultMap">
        SELECT * FROM password_reset_tokens WHERE token = #{token}
    </select>

    <update id="markUsed">
        UPDATE password_reset_tokens SET used_at = NOW() WHERE id = #{id}
    </update>

</mapper>