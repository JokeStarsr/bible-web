<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bible.module.auth.mapper.EmailVerificationTokenMapper">

    <resultMap id="EmailVerificationTokenResultMap" type="com.bible.module.auth.entity.EmailVerificationToken">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="token" property="token"/>
        <result column="expires_at" property="expiresAt"/>
        <result column="verified_at" property="verifiedAt"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <insert id="insert">
        INSERT INTO email_verification_tokens(id, user_id, token, expires_at, verified_at, created_at)
        VALUES(gen_random_uuid(), #{userId}, #{token}, #{expiresAt}, #{verifiedAt}, NOW())
    </insert>

    <select id="findByToken" resultMap="EmailVerificationTokenResultMap">
        SELECT * FROM email_verification_tokens WHERE token = #{token}
    </select>

    <update id="markVerified">
        UPDATE email_verification_tokens SET verified_at = NOW() WHERE id = #{id}
    </update>

</mapper>